[sub_resource type="Resource" id="Resource_5ihvl"]
script = ExtResource("1_u3xqu")
text = "[Charm] \"If a drink is all you want, stranger, I have plenty. But don't you think a story would be nice?\""
stat = "charm"
difficulty = 8
time_reward = 60.0
success_blocks = Array[String](["\"I suppose a story wouldn't hurt. Go ahead.\""])
fail_blocks = Array[String](["A frown crosses the person's face - not one of annoyance, but of resignation.", "\"Stories may be nice, but it would take too much time now.\""])
metadata/_custom_type_script = "uid://b2hfg3suqs6q8"

